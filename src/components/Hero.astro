---
interface Props {
  name: string;
  tagline: string;
}

const { name, tagline } = Astro.props;
const letters = name.split('');
---

<section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden">
  <div class="absolute inset-0 grid-pattern opacity-30"></div>
  
  <div class="container relative z-10 text-center">
    <h1 class="mb-6">
      <span class="sr-only">{name}</span>
      <span 
        class="hero-name inline-block text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight"
        aria-hidden="true"
      >
        {letters.map((letter, index) => (
          <span 
            class="hero-letter inline-block opacity-0"
            style={`animation-delay: ${300 + index * 50}ms`}
          >
            {letter === ' ' ? '\u00A0' : letter}
          </span>
        ))}
      </span>
    </h1>
    
    <p class="hero-tagline text-lg md:text-xl text-muted max-w-xl mx-auto opacity-0">
      {tagline}
    </p>
    
    <div class="hero-cta mt-10 flex items-center justify-center gap-4 opacity-0">
      <a href="/#projects" class="btn btn-primary">
        View Projects
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <polyline points="19 12 12 19 5 12"></polyline>
        </svg>
      </a>
      <a href="/about" class="btn btn-secondary">
        About Me
      </a>
    </div>
  </div>
  
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </div>
</section>

<style>
  .hero-letter {
    animation: letterIn 0.5s ease-out forwards;
  }
  
  .hero-tagline {
    animation: fadeUp 0.6s ease-out 0.8s forwards;
  }
  
  .hero-cta {
    animation: fadeUp 0.6s ease-out 1s forwards;
  }
  
  @keyframes letterIn {
    0% {
      opacity: 0;
      transform: translateY(20px) rotateX(-20deg);
    }
    100% {
      opacity: 1;
      transform: translateY(0) rotateX(0);
    }
  }
  
  @keyframes fadeUp {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
