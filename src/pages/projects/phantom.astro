---
import Layout from '../../layouts/Layout.astro';
import PhantomVideo from '../../components/demos/PhantomVideo';
import projectsData from '../../data/projects.json';

const project = projectsData.projects.find(p => p.slug === 'phantom');
---

<Layout title={`${project?.title} | Leonel Lourenco`}>
  <section class="section">
    <div class="container">
      <a href="/#projects" class="inline-flex items-center gap-2 text-muted hover:text-accent mb-8 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Projects
      </a>
      
      <div class="mb-8">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {project?.tags.map((tag) => (
            <span class="badge badge-default">{tag}</span>
          ))}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{project?.title}</h1>
        <p class="text-lg text-muted max-w-2xl">{project?.description}</p>
      </div>
      
      <div class="mb-12">
        <div class="bg-border/30 rounded-lg p-4 mb-4">
          <div class="flex items-center gap-2 text-sm text-muted mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polygon points="10 8 16 12 10 16 10 8"></polygon>
            </svg>
            <span>Video Demo — Watch Phantom in action with chapter navigation</span>
          </div>
        </div>
        
        <div class="border border-border rounded-lg overflow-hidden bg-secondary">
          <PhantomVideo client:load />
        </div>
      </div>
      
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold mb-4">About This Project</h2>
        <p class="text-muted mb-6">{project?.longDescription}</p>
        
        <h3 class="text-lg font-bold mb-3">Key Features</h3>
        <ul class="space-y-2 mb-8">
          {project?.features.map((feature) => (
            <li class="flex items-start gap-3 text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              {feature}
            </li>
          ))}
        </ul>
        
        <h3 class="text-lg font-bold mb-3">Technology Stack</h3>
        <div class="flex flex-wrap gap-2">
          {project?.tags.map((tag) => (
            <span class="px-4 py-2 bg-border/50 rounded-md text-sm font-medium">{tag}</span>
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
