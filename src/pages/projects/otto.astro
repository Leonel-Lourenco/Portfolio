---
import Layout from '../../layouts/Layout.astro';
import OttoVideo from '../../components/demos/OttoVideo';
import projectsData from '../../data/projects.json';

const project = projectsData.projects.find(p => p.slug === 'otto');
---

<Layout title={`${project?.title} | Leonel Lourenco`}>
  <section class="section">
    <div class="container">
      <a href="/#projects" class="inline-flex items-center gap-2 text-muted hover:text-accent mb-8 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        Back to Projects
      </a>
      
      <div class="mb-8">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {project?.tags.map((tag) => (
            <span class="badge badge-default">{tag}</span>
          ))}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{project?.title}</h1>
        <p class="text-lg text-muted max-w-2xl">{project?.description}</p>
      </div>
      
      <div class="mb-12">
        <div class="bg-border/30 rounded-lg p-4 mb-4">
          <div class="flex items-center gap-2 text-sm text-muted mb-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <polygon points="10 8 16 12 10 16 10 8"></polygon>
            </svg>
            <span>Video Demo — Watch Otto transform templates into professional stores</span>
          </div>
        </div>
        
        <div class="border border-border rounded-lg overflow-hidden bg-secondary">
          <OttoVideo client:load />
        </div>
      </div>
      
      <div class="max-w-2xl">
        <h2 class="text-2xl font-bold mb-4">About This Project</h2>
        <p class="text-muted mb-6">{project?.longDescription}</p>
        
        <h3 class="text-lg font-bold mb-3">Key Features</h3>
        <ul class="space-y-2 mb-8">
          {project?.features.map((feature) => (
            <li class="flex items-start gap-3 text-muted">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-accent mt-0.5 flex-shrink-0">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              {feature}
            </li>
          ))}
        </ul>
        
        <h3 class="text-lg font-bold mb-3">Technology Stack</h3>
        <div class="flex flex-wrap gap-2">
          {project?.tags.map((tag) => (
            <span class="px-4 py-2 bg-border/50 rounded-md text-sm font-medium">{tag}</span>
          ))}
        </div>
      </div>
      
      <!-- Contact Section -->
      <div class="mt-16 pt-12 border-t border-border">
        <div class="max-w-2xl">
          <h2 class="text-2xl font-bold mb-4">Get In Touch</h2>
          <p class="text-muted mb-6">
            Interested in learning more about Otto or discussing a similar project? I'd love to hear from you.
          </p>
          
          <div class="flex flex-wrap gap-4">
            <a 
              href="mailto:leoneldlourenco@outlook.com" 
              class="inline-flex items-center gap-2 px-6 py-3 bg-primary text-secondary rounded-lg font-medium hover:bg-accent transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"></rect>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
              </svg>
              Email Me
            </a>
            
            <a 
              href="https://www.linkedin.com/in/leonel-lourenco/" 
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 border border-border rounded-lg font-medium hover:border-accent hover:text-accent transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect width="4" height="12" x="2" y="9"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
              LinkedIn
            </a>
            
            <a 
              href="https://github.com/leonellourenco" 
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 border border-border rounded-lg font-medium hover:border-accent hover:text-accent transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                <path d="M9 18c-4.51 2-5-2-7-2"></path>
              </svg>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
